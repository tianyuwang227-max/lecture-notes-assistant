{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "听课笔记 Todo",
  "version": "0.2.0",
  "identifier": "com.clay.lecture-notes-todo",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "今日 Todo",
        "url": "http://localhost:5174/#mini",
        "width": 360,
        "height": 540,
        "alwaysOnTop": true,
        "decorations": true,
        "resizable": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
